{
  "name": "child-growth-guide",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "typecheck": "vue-tsc -b",
    "test": "vitest run",
    "e2e": "sh -c 'pnpm exec vite --host 127.0.0.1 --port 5185 >/tmp/child-growth-vite-e2e.log 2>&1 & VITE_PID=$!; trap \"kill $VITE_PID\" EXIT; until curl --noproxy \"*\" -s http://127.0.0.1:5185/ >/dev/null; do sleep 0.2; done; playwright test'",
    "e2e:report": "playwright show-report",
    "convert:data": "tsx scripts/convert-seed.ts"
  },
  "dependencies": {
    "@vitejs/plugin-vue": "^5.2.3",
    "pinia": "^3.0.2",
    "vite": "^6.3.5",
    "vue": "^3.5.13",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^22.15.3",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.4.21",
    "jsdom": "^26.1.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2",
    "vue-tsc": "^2.2.10"
  }
}
